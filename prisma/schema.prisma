generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// PRATICA — entità centrale del sistema
// ---------------------------------------------------------------------------
model Pratica {
  id             Int          @id @default(autoincrement())
  tipo           TipoPratica
  delega         Delega
  titolo         String
  descrizione    String?
  luogo          String?
  stato          StatoPratica @default(APERTA)
  priorita       Priorita     @default(MEDIA)
  protocollo     String?
  dataProtocollo String?
  messageId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  chiusaAt       DateTime?

  segnalante   Segnalante?
  personaId    Int?
  persona      Persona?       @relation(fields: [personaId], references: [id])
  foto         Foto[]
  note         Nota[]
  appuntamenti Appuntamento[]
  storico      StoricoStato[]
  mailInviate  MailInviata[]
}

// ---------------------------------------------------------------------------
// SEGNALANTE — dati del cittadino che ha fatto la segnalazione
// ---------------------------------------------------------------------------
model Segnalante {
  id        Int     @id @default(autoincrement())
  praticaId Int     @unique
  pratica   Pratica @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  nome      String?
  telefono  String?
  email     String?
}

// ---------------------------------------------------------------------------
// PERSONA — rubrica referenti (capisettore, esterni, cittadini ricorrenti)
// ---------------------------------------------------------------------------
model Persona {
  id              Int        @id @default(autoincrement())
  nome            String
  cognome         String
  ruolo           String?
  telefono        String?
  email           String?
  emailSecondaria String?
  azienda         String?
  createdAt       DateTime   @default(now())
  pratiche        Pratica[]
  progetti        Progetto[]
  riunioni        Riunione[]
}

// ---------------------------------------------------------------------------
// FOTO — allegati fotografici
// ---------------------------------------------------------------------------
model Foto {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// NOTA — log editabile, ogni voce è un record separato (audit trail)
// ---------------------------------------------------------------------------
model Nota {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  testo     String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// STORICO STATO — audit trail dei cambi di stato
// ---------------------------------------------------------------------------
model StoricoStato {
  id              Int           @id @default(autoincrement())
  praticaId       Int
  pratica         Pratica       @relation(fields: [praticaId], references: [id])
  statoPrecedente StatoPratica?
  statoNuovo      StatoPratica
  createdAt       DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// APPUNTAMENTO — collegabile a una pratica, sincronizzato con Google Calendar
// ---------------------------------------------------------------------------
model Appuntamento {
  id            Int      @id @default(autoincrement())
  praticaId     Int?
  pratica       Pratica? @relation(fields: [praticaId], references: [id])
  titolo        String
  descrizione   String?
  luogo         String?
  dataOra       DateTime
  googleEventId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// MAIL INVIATA — storico risposte inviate via Gmail dalla pratica
// ---------------------------------------------------------------------------
model MailInviata {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  to        String
  oggetto   String
  corpo     String
  sentAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// PROGETTO — amministrativo, separato dalle Segnalazioni (ex TipoPratica.PROGETTO)
// ---------------------------------------------------------------------------
model Progetto {
  id                 String              @id @default(cuid())
  titolo             String
  delega             Delega
  stato              StatoProgetto       @default(IN_CORSO)
  responsabileId     Int?
  responsabile       Persona?            @relation(fields: [responsabileId], references: [id])
  fonteFinanziamento String?
  bandoId            String?
  descrizione        String?
  protocollo         String?
  note               NotaProgetto[]
  documenti          DocumentoProgetto[]
  riunioni           Riunione[]
  messageId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum StatoProgetto {
  IN_CORSO
  SOSPESO
  CONCLUSO
  ARCHIVIATO
}

model NotaProgetto {
  id         String   @id @default(cuid())
  progettoId String
  progetto   Progetto @relation(fields: [progettoId], references: [id], onDelete: Cascade)
  testo      String
  createdAt  DateTime @default(now())
}

model DocumentoProgetto {
  id         String   @id @default(cuid())
  progettoId String
  progetto   Progetto @relation(fields: [progettoId], references: [id], onDelete: Cascade)
  nomeFile   String
  storageUrl String
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// RIUNIONE — checklist vocale per preparare e seguire incontri
// ---------------------------------------------------------------------------
model Riunione {
  id                 String              @id @default(cuid())
  titolo             String
  personaId          Int?
  persona            Persona?            @relation(fields: [personaId], references: [id])
  progettoId         String?
  progetto           Progetto?           @relation(fields: [progettoId], references: [id])
  dataOra            DateTime?
  stato              StatoRiunione       @default(IN_PREPARAZIONE)
  priorita           Priorita?
  trascrizioneGrezza String?             @db.Text
  argomenti          ArgomentoRiunione[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model ArgomentoRiunione {
  id         String    @id @default(cuid())
  riunioneId String
  riunione   Riunione  @relation(fields: [riunioneId], references: [id], onDelete: Cascade)
  testo      String
  ordine     Int
  spuntato   Boolean   @default(false)
  spuntatoAt DateTime?
  createdAt  DateTime  @default(now())
}

enum StatoRiunione {
  IN_PREPARAZIONE
  PRONTA
  IN_CORSO
  CONCLUSA
}

// ---------------------------------------------------------------------------
// CONTESTAZIONE — mail del Comune verso i gestori per mancato ritiro/servizio
// ---------------------------------------------------------------------------
model Contestazione {
  id          String                   @id @default(cuid())
  gestore     Gestore
  oggetto     String
  descrizione String?
  dataInvio   DateTime?
  esito       EsitoContestazione       @default(IN_ATTESA)
  noteEsito   String?
  protocollo  String?
  note        NotaContestazione[]
  documenti   DocumentoContestazione[]
  messageId   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model NotaContestazione {
  id              String        @id @default(cuid())
  contestazioneId String
  contestazione   Contestazione @relation(fields: [contestazioneId], references: [id], onDelete: Cascade)
  testo           String
  createdAt       DateTime      @default(now())
}

enum Gestore {
  ACAM_AMBIENTE
  ACAM_ACQUE
  ATC
}

enum EsitoContestazione {
  IN_ATTESA
  RISOLTO
  RESPINTO
  SENZA_RISPOSTA
}

model DocumentoContestazione {
  id              String        @id @default(cuid())
  contestazioneId String
  contestazione   Contestazione @relation(fields: [contestazioneId], references: [id], onDelete: Cascade)
  nomeFile        String
  storageUrl      String
  createdAt       DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// GIUSTIFICA — checklist inoltro giustifiche al datore di lavoro
// ---------------------------------------------------------------------------
model Giustifica {
  id              String                @id @default(cuid())
  ufficioMittente String?
  oggetto         String
  dataRicezione   DateTime              @default(now())
  inoltrata       Boolean               @default(false)
  inoltrataAt     DateTime?
  visualizzata    Boolean               @default(false)
  visualizzataAt  DateTime?
  documenti       DocumentoGiustifica[]
  messageId       String?
  createdAt       DateTime              @default(now())
}

model DocumentoGiustifica {
  id           String     @id @default(cuid())
  giustificaId String
  giustifica   Giustifica @relation(fields: [giustificaId], references: [id], onDelete: Cascade)
  nomeFile     String
  storageUrl   String
  createdAt    DateTime   @default(now())
}

// ---------------------------------------------------------------------------
// ATTO POLITICO-AMMINISTRATIVO — Giunta, Consiglio, Commissioni, Mozioni, Interrogazioni
// ---------------------------------------------------------------------------
model AttoPoliticoAmministrativo {
  id                   String                       @id @default(cuid())
  tipo                 TipoAtto
  dataSeduta           DateTime?
  oggetto              String
  odgTestoEstratto     String?                      @db.Text
  scadenzaRisposta     DateTime?
  consiglioCollegatoId String?
  consiglioCollegato   AttoPoliticoAmministrativo?  @relation("RispostaInConsiglio", fields: [consiglioCollegatoId], references: [id])
  risposteCollegate    AttoPoliticoAmministrativo[] @relation("RispostaInConsiglio")
  stato                StatoAtto                    @default(DA_ESAMINARE)
  priorita             Priorita?
  visualizzato         Boolean                      @default(false)
  visualizzatoAt       DateTime?
  documenti            DocumentoAtto[]
  messageId            String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
}

enum TipoAtto {
  CONVOCAZIONE_GIUNTA
  CONVOCAZIONE_CONSIGLIO
  CONVOCAZIONE_COMMISSIONE
  MOZIONE
  INTERROGAZIONE
}

enum StatoAtto {
  DA_ESAMINARE
  ESAMINATO
  RISPOSTO
  ARCHIVIATO
}

model DocumentoAtto {
  id         String                     @id @default(cuid())
  attoId     String
  atto       AttoPoliticoAmministrativo @relation(fields: [attoId], references: [id], onDelete: Cascade)
  nomeFile   String
  storageUrl String
  ruolo      RuoloDocumento             @default(PRATICA_ALLEGATA)
  createdAt  DateTime                   @default(now())
}

enum RuoloDocumento {
  ORDINE_GIORNO
  PRATICA_ALLEGATA
}

// ---------------------------------------------------------------------------
// MAIL PROCESSATA — log di verità del motore di scansione mail (sezione 6 spec):
// il DB, non le etichette Gmail, decide cosa è già stato gestito.
// ---------------------------------------------------------------------------
model MailProcessata {
  id                String              @id @default(cuid())
  messageId         String              @unique
  threadId          String?
  mittente          String?
  oggetto           String?
  categoriaProposta String?
  confidenza        Float?
  binario           BinarioMail
  esito             EsitoMailProcessata @default(IN_ATTESA)
  entitaCreataId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

enum BinarioMail {
  AUTOMATICO
  MANUALE
  INCERTO
  // Mail fuori scope per il tool (newsletter, bollettini, inviti — non spam in senso
  // stretto, solo non pertinente): risolta subito in COMPLETATO durante lo scan stesso,
  // salta di proposito il gate "prima esecuzione" — non crea né modifica nulla nel DB
  // del tool, quindi non c'è un'azione reale da cui proteggersi rimandandola. Vedi
  // NOTE-TECNICHE.md per il confronto con PROPOSTA_CONTINUAZIONE, che invece rispetta
  // il gate perché comporta un'azione reale (creare o collegare un'entità).
  NON_RILEVANTE
  // Match debole nella catena di riconoscimento continuazione (oggetto normalizzato +
  // mittente/destinatario, senza protocollo/threadId a confermare): propone di agganciare
  // la mail a un'entità esistente, ma richiede sempre conferma umana — mai eseguito da solo.
  PROPOSTA_CONTINUAZIONE
}

enum EsitoMailProcessata {
  IN_ATTESA
  COMPLETATO
  ERRORE
}

// ---------------------------------------------------------------------------
// BANDO — monitoraggio bandi pubblici rilevanti per le deleghe
// ---------------------------------------------------------------------------
model Bando {
  id               String            @id @default(cuid())
  titolo           String
  ente             String
  fonteUrl         String
  bandoUrl         String?
  descrizione      String?
  dotazione        String?
  beneficiari      String?
  dataApertura     DateTime?
  dataChiusura     DateTime?
  delega           Delega?
  hashContenuto    String            @unique
  stato            StatoBando        @default(NUOVO)
  notificato       Boolean           @default(false)
  // Estratti via AI (lib/bandi/estrazione-ai.ts) dal testo della pagina — solo informativi,
  // nessun filtro escludente automatico: null se il bando non specifica un tetto/tipo esplicito.
  sogliaPopolazione Int?
  tipoBeneficiario  TipoBeneficiario?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

enum TipoBeneficiario {
  ENTE_PUBBLICO
  IMPRESA
  MISTO
  CITTADINO
}

enum StatoBando {
  NUOVO
  VALUTATO
  INTERESSANTE
  SCARTATO
  SCADUTO
}

// ---------------------------------------------------------------------------
// UTENTE — solo Marco (sistema single-user)
// ---------------------------------------------------------------------------
model Utente {
  id             Int      @id @default(autoincrement())
  nome           String
  email          String   @unique
  passwordHash   String
  attivo         Boolean  @default(true)
  telegramChatId BigInt?
  createdAt      DateTime @default(now())
}

// ---------------------------------------------------------------------------
// ENUMERAZIONI
// ---------------------------------------------------------------------------

enum TipoPratica {
  SEGNALAZIONE
  MIA_IDEA
  PROGETTO
}

enum Delega {
  VIABILITA
  AMBIENTE
  RIFIUTI
  SISTEMA_IDRICO
  ILLUMINAZIONE
  ACCESSIBILITA
  CIMITERI
  POLITICHE_ABITATIVE
  DIGITALIZZAZIONE
  MANUTENZIONE_PATRIMONIO
}

enum StatoPratica {
  APERTA
  IN_CORSO
  CHIUSA
  SOSPESA
  APPUNTO
  IN_VALUTAZIONE
  PROMOSSA
  ARCHIVIATA
}

enum Priorita {
  BASSA
  MEDIA
  ALTA
}
