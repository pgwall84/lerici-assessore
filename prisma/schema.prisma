generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// PRATICA — entità centrale del sistema
// ---------------------------------------------------------------------------
model Pratica {
  id          Int          @id @default(autoincrement())
  tipo        TipoPratica
  delega      Delega
  titolo      String
  descrizione String?
  luogo       String?
  stato       StatoPratica @default(APERTA)
  priorita    Priorita     @default(MEDIA)
  protocollo     String?
  dataProtocollo String?
  messageId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  chiusaAt    DateTime?

  segnalante   Segnalante?
  personaId    Int?
  persona      Persona?       @relation(fields: [personaId], references: [id])
  foto         Foto[]
  note         Nota[]
  appuntamenti Appuntamento[]
  storico      StoricoStato[]
  mailInviate  MailInviata[]
}

// ---------------------------------------------------------------------------
// SEGNALANTE — dati del cittadino che ha fatto la segnalazione
// ---------------------------------------------------------------------------
model Segnalante {
  id        Int     @id @default(autoincrement())
  praticaId Int     @unique
  pratica   Pratica @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  nome      String?
  telefono  String?
  email     String?
}

// ---------------------------------------------------------------------------
// PERSONA — rubrica referenti (capisettore, esterni, cittadini ricorrenti)
// ---------------------------------------------------------------------------
model Persona {
  id        Int       @id @default(autoincrement())
  nome      String
  cognome   String
  ruolo     String?
  telefono  String?
  email     String?
  createdAt DateTime  @default(now())
  pratiche  Pratica[]
  progetti  Progetto[]
  riunioni  Riunione[]
}

// ---------------------------------------------------------------------------
// FOTO — allegati fotografici
// ---------------------------------------------------------------------------
model Foto {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// NOTA — log editabile, ogni voce è un record separato (audit trail)
// ---------------------------------------------------------------------------
model Nota {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  testo     String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// STORICO STATO — audit trail dei cambi di stato
// ---------------------------------------------------------------------------
model StoricoStato {
  id              Int           @id @default(autoincrement())
  praticaId       Int
  pratica         Pratica       @relation(fields: [praticaId], references: [id])
  statoPrecedente StatoPratica?
  statoNuovo      StatoPratica
  createdAt       DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// APPUNTAMENTO — collegabile a una pratica, sincronizzato con Google Calendar
// ---------------------------------------------------------------------------
model Appuntamento {
  id            Int      @id @default(autoincrement())
  praticaId     Int?
  pratica       Pratica? @relation(fields: [praticaId], references: [id])
  titolo        String
  descrizione   String?
  luogo         String?
  dataOra       DateTime
  googleEventId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// MAIL INVIATA — storico risposte inviate via Gmail dalla pratica
// ---------------------------------------------------------------------------
model MailInviata {
  id        Int      @id @default(autoincrement())
  praticaId Int
  pratica   Pratica  @relation(fields: [praticaId], references: [id], onDelete: Cascade)
  to        String
  oggetto   String
  corpo     String
  sentAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// PROGETTO — amministrativo, separato dalle Segnalazioni (ex TipoPratica.PROGETTO)
// ---------------------------------------------------------------------------
model Progetto {
  id                 String              @id @default(cuid())
  titolo             String
  delega             Delega
  stato              StatoProgetto       @default(IN_CORSO)
  responsabileId     Int?
  responsabile       Persona?            @relation(fields: [responsabileId], references: [id])
  fonteFinanziamento String?
  bandoId            String?
  descrizione        String?
  note               NotaProgetto[]
  documenti          DocumentoProgetto[]
  riunioni           Riunione[]
  messageId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum StatoProgetto {
  IN_CORSO
  SOSPESO
  CONCLUSO
  ARCHIVIATO
}

model NotaProgetto {
  id         String   @id @default(cuid())
  progettoId String
  progetto   Progetto @relation(fields: [progettoId], references: [id], onDelete: Cascade)
  testo      String
  createdAt  DateTime @default(now())
}

model DocumentoProgetto {
  id         String   @id @default(cuid())
  progettoId String
  progetto   Progetto @relation(fields: [progettoId], references: [id], onDelete: Cascade)
  nomeFile   String
  storageUrl String
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// RIUNIONE — checklist vocale per preparare e seguire incontri
// ---------------------------------------------------------------------------
model Riunione {
  id                 String              @id @default(cuid())
  titolo             String
  personaId          Int?
  persona            Persona?            @relation(fields: [personaId], references: [id])
  progettoId         String?
  progetto           Progetto?           @relation(fields: [progettoId], references: [id])
  dataOra            DateTime?
  stato              StatoRiunione       @default(IN_PREPARAZIONE)
  trascrizioneGrezza String?             @db.Text
  argomenti          ArgomentoRiunione[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model ArgomentoRiunione {
  id         String    @id @default(cuid())
  riunioneId String
  riunione   Riunione  @relation(fields: [riunioneId], references: [id], onDelete: Cascade)
  testo      String
  ordine     Int
  spuntato   Boolean   @default(false)
  spuntatoAt DateTime?
  createdAt  DateTime  @default(now())
}

enum StatoRiunione {
  IN_PREPARAZIONE
  PRONTA
  IN_CORSO
  CONCLUSA
}

// ---------------------------------------------------------------------------
// BANDO — monitoraggio bandi pubblici rilevanti per le deleghe
// ---------------------------------------------------------------------------
model Bando {
  id              String     @id @default(cuid())
  titolo          String
  ente            String
  fonteUrl        String
  bandoUrl        String?
  descrizione     String?
  dotazione       String?
  beneficiari     String?
  dataApertura    DateTime?
  dataChiusura    DateTime?
  delega          Delega?
  hashContenuto   String     @unique
  stato           StatoBando @default(NUOVO)
  notificato      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

enum StatoBando {
  NUOVO
  VALUTATO
  INTERESSANTE
  SCARTATO
  SCADUTO
}

// ---------------------------------------------------------------------------
// UTENTE — solo Marco (sistema single-user)
// ---------------------------------------------------------------------------
model Utente {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  passwordHash String
  attivo       Boolean  @default(true)
  telegramChatId BigInt?
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// ENUMERAZIONI
// ---------------------------------------------------------------------------

enum TipoPratica {
  SEGNALAZIONE
  MIA_IDEA
  PROGETTO
}

enum Delega {
  VIABILITA
  AMBIENTE
  RIFIUTI
  SISTEMA_IDRICO
  ILLUMINAZIONE
  ACCESSIBILITA
  CIMITERI
  POLITICHE_ABITATIVE
  DIGITALIZZAZIONE
  MANUTENZIONE_PATRIMONIO
}

enum StatoPratica {
  APERTA
  IN_CORSO
  CHIUSA
  SOSPESA
  APPUNTO
  IN_VALUTAZIONE
  PROMOSSA
  ARCHIVIATA
}

enum Priorita {
  BASSA
  MEDIA
  ALTA
}
